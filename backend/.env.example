# === PRODUCTION CONFIGURATION ===

# Server Port (Railway sets this automatically)
PORT=8080
NODE_ENV=production

# Database
MONGO_URI=mongodb+srv://username:password@cluster.example.com/nutriflow?retryWrites=true&w=majority

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend-url.railway.app

# JWT
JWT_SECRET=a-very-long-random-secret-key-at-least-32-characters

# === OPENAI CONFIGURATION ===
# Get your API key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# === STRIPE CONFIGURATION ===
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_PRICE_ID=price_abcdefgh123456
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# === EMAIL CONFIGURATION ===
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password

# === DEVELOPMENT (for local testing) ===
# PORT=5000
# NODE_ENV=development
# MONGO_URI=mongodb://localhost:27017/nutriflow
# FRONTEND_URL=http://localhost:3000
# OPENAI_API_KEY=sk-proj-your-test-key
# STRIPE_SECRET_KEY=sk_test_your_test_key
# STRIPE_PRICE_ID=price_test_XXXX
# STRIPE_WEBHOOK_SECRET=whsec_test_XXXX
# EMAIL_USER=you@example.com
# EMAIL_PASS=your-email-password
